# =============================================================================
# Aurora Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# 
# QUICK START (local development):
#   make init  # Auto-generates secrets
#   Add OPENROUTER_API_KEY (get from https://openrouter.ai/keys)
#   make prod-prebuilt   # or: make prod-local to build from source
# =============================================================================

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------
AURORA_ENV=dev

# Frontend dev server (make dev only; prod-local ignores this)
# bun  - Bun process + Turbopack (default)
# node - Node process + Webpack (use if frontend dev OOMs in Docker Desktop)
FRONTEND_DEV_RUNTIME=bun

# -----------------------------------------------------------------------------
# Database [REQUIRED]
# -----------------------------------------------------------------------------
POSTGRES_USER=aurora
POSTGRES_PASSWORD=
POSTGRES_DB=aurora_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_POOL_MIN=2
DB_POOL_MAX=20

# -----------------------------------------------------------------------------
# Concurrency
# -----------------------------------------------------------------------------
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
CELERY_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Object Storage (S3-compatible)
# -----------------------------------------------------------------------------
# Default: SeaweedFS (included in docker-compose)
# Production: AWS S3, Cloudflare R2, MinIO, etc.
STORAGE_BUCKET=aurora-storage
STORAGE_ENDPOINT_URL=http://seaweedfs-filer:8333
STORAGE_ACCESS_KEY=admin
STORAGE_SECRET_KEY=admin
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false
STORAGE_VERIFY_SSL=false
STORAGE_CACHE_ENABLED=true
STORAGE_CACHE_TTL=60

# -----------------------------------------------------------------------------
# URLs & Networking
# -----------------------------------------------------------------------------
# These NEXT_PUBLIC_* vars are injected at container startup (not baked at build).
# Change them in .env and recreate the frontend container to take effect:
#   docker compose -f docker-compose.prod-local.yml up -d frontend
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://aurora-server:5080
NEXT_PUBLIC_BACKEND_URL=http://localhost:5080
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:5006
CHATBOT_INTERNAL_URL=http://chatbot:5007

# -----------------------------------------------------------------------------
# Authentication & Security [REQUIRED]
# -----------------------------------------------------------------------------
# Auto-generated by: make init
FLASK_SECRET_KEY=
FLASK_PORT=5080
AUTH_SECRET=
# Leave blank to disable (not recommended in production).
INTERNAL_API_SECRET=

# Secrets backend: "vault" (default) or "aws_secrets_manager"
SECRETS_BACKEND=vault

# HashiCorp Vault (default backend)
VAULT_TOKEN=
VAULT_ADDR=http://vault:8200
VAULT_KV_MOUNT=aurora
VAULT_KV_BASE_PATH=users

# AWS Secrets Manager (only when SECRETS_BACKEND=aws_secrets_manager)
AWS_SM_REGION=
AWS_SM_PREFIX=aurora/users
# Dedicated credentials for Secrets Manager access. Keeps SM auth separate from
# the AWS connector's AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY (used for cross-account
# STS AssumeRole). Falls back to the default boto3 credential chain if unset.
AWS_SM_ACCESS_KEY_ID=
AWS_SM_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# LLM & AI Services [REQUIRED]
# -----------------------------------------------------------------------------
# At least one API key required. OpenRouter recommended (supports multiple models).
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Provider mode: "openrouter" (default, uses OpenRouter as proxy), "direct" (native APIs), "auto"
LLM_PROVIDER_MODE=openrouter
AGENT_RECURSION_LIMIT=240

# --- AI Safety Guardrails ---
# Three-layer defense: input rail for prompt injection on the user message, then
# signature matcher + LLM safety judge on every shell command. Judge and input
# rail fail closed on any error. Adapted from Meta's PurpleLlama (MIT licensed).
#
# Master switch (default: true). When true, all three layers run.
# Set to false to disable all guardrails.
# Configure the LLM model via GUARDRAILS_LLM_MODEL in the model overrides
# section below; when unset, defaults to google/gemini-2.5-flash-lite under
# LLM_PROVIDER_MODE=openrouter, otherwise to MAIN_MODEL.
GUARDRAILS_ENABLED=true

# Gate the vendored SigmaHQ rule corpus inside the signature matcher
# (default: true). Requires GUARDRAILS_ENABLED=true. Set to false to
# run only hand-written rules.
GUARDRAILS_SIGMA_ENABLED=true

# Web Search (SearXNG)
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET=

# AI Features
RCA_OPTIMIZE_COSTS=false
GEMINI_DISABLE_THINKING=

# Multi-agent RCA orchestrator. When true (default), a lead orchestrator
# triages each background RCA and may fan out parallel read-only sub-agents.
# When false, background RCA falls back to the legacy single-agent ReAct loop.
# When true, RCA_ORCHESTRATOR_MODEL and RCA_SUBAGENT_MODEL must also be set
# (see model overrides section below) — otherwise triage will fail loudly and
# the run gracefully degrades to single-agent mode.
ORCHESTRATOR_ENABLED=true

# Optional: Token budget for auto-loaded integration skills during background RCA.
# Defaults to 12000. Set higher to include more integration context, lower to save tokens.
RCA_SKILLS_TOKEN_BUDGET=
RCA_TOKEN_BUDGET=

# Model overrides — defaults vary by setting; see each variable below.
# Use provider/model format (e.g., openai/gpt-4.1, google/gemini-2.5-pro, ollama/llama3.1).

# Main model for chat and agent workflows.
MAIN_MODEL=

# RCA model for background root-cause analysis.
# Defaults to anthropic/claude-haiku-4.5 when RCA_OPTIMIZE_COSTS=true, else anthropic/claude-opus-4.6
RCA_MODEL=

# Multi-agent RCA orchestrator models. Required when ORCHESTRATOR_ENABLED=true.
# Independent of MAIN_MODEL (chat) and RCA_MODEL (legacy single-agent RCA).
# No automatic fallback — set explicitly or orchestrator nodes will error out
# and the run gracefully degrades to single-agent mode.

# Brain model for triage + synthesis decisions. Needs reliable structured-output JSON.
RCA_ORCHESTRATOR_MODEL=

# Sub-agent investigator model. Needs reliable tool-calling — must always end its
# turn with a tool call (including the terminal `write_findings`).
RCA_SUBAGENT_MODEL=

# Vision model for multimodal tasks. Defaults to MAIN_MODEL if not set.
VISION_MODEL=

# Summarization model for incident reports and tool output. Defaults to MAIN_MODEL if not set.
SUMMARIZATION_MODEL=

# Safety judge model for the AI guardrails layer (only used when GUARDRAILS_ENABLED=true).
# When unset, defaults to google/gemini-2.5-flash-lite under LLM_PROVIDER_MODE=openrouter,
# otherwise falls back to MAIN_MODEL. A small, fast model is recommended since it runs on
# every command execution. Same provider/model format as MAIN_MODEL.
#
# IMPORTANT: Choose a non-reasoning model. The safety judge is a binary Yes/No classifier;
# reasoning/thinking models (e.g. gpt-5.4-mini, gemini-2.5-pro, o3-mini) waste their output
# token budget on chain-of-thought, adding seconds of latency and cost for no classification
# benefit. Good choices: gpt-4o-mini, claude-haiku-4.5, gemini-2.0-flash, gemini-2.5-flash-lite.
GUARDRAILS_LLM_MODEL=

# Vertex AI (Google Cloud) - set VERTEX_AI_PROJECT + one auth method
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=global
VERTEX_AI_SERVICE_ACCOUNT_JSON=

# Ollama (local LLM inference) - install Ollama on host, pull models with `ollama pull <model>`
OLLAMA_BASE_URL=http://host.docker.internal:11434

# -----------------------------------------------------------------------------
# Cloud Provider Integrations (Optional)
# -----------------------------------------------------------------------------

# GCP
CLIENT_ID=
CLIENT_SECRET=

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Cloud Provider Cache (applies to all providers)
AURORA_SETUP_CACHE_ENABLED=true
AURORA_SETUP_CACHE_TTL=3600
AURORA_VERIFY_CLI_IDENTITY=false
AURORA_CACHE_TOKEN_IN_REDIS=false

# -----------------------------------------------------------------------------
# Third-Party Integrations (Optional)
# -----------------------------------------------------------------------------

# GitHub auth mode: app | oauth | hybrid (default: app)
#   app    — GitHub App only (recommended, the only path most deployments need)
#   oauth  — Legacy user OAuth only. For on-prem deployments that cannot host
#            their own GitHub App. Requires GH_OAUTH_CLIENT_ID/SECRET below.
#   hybrid — Both paths active. Frontend dialog shows both CTAs; auth router
#            prefers App tokens and falls back to OAuth.
GITHUB_AUTH_MODE=app

# GitHub App. See server/connectors/github_connector/SETUP_GITHUB_APP.md or run
# `python3 server/scripts/register_github_app.py --org <your-org>` to bootstrap.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_APP_WEBHOOK_URL=
GITHUB_APP_SETUP_URL=
# Fallback used when the value is not stored in Vault.
GITHUB_APP_WEBHOOK_SECRET=

# GitHub OAuth (only required when GITHUB_AUTH_MODE=oauth or =hybrid).
# Create at https://github.com/settings/developers > New OAuth App.
# Authorization callback URL must be: <NEXT_PUBLIC_BACKEND_URL>/github/callback
GH_OAUTH_CLIENT_ID=
GH_OAUTH_CLIENT_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Google Chat (OAuth for setup, service account for messaging)
GOOGLE_CHAT_CLIENT_ID=
GOOGLE_CHAT_CLIENT_SECRET=
GOOGLE_CHAT_SERVICE_ACCOUNT_KEY=

# PagerDuty
NEXT_PUBLIC_ENABLE_PAGERDUTY_OAUTH=false
PAGERDUTY_CLIENT_ID=
PAGERDUTY_CLIENT_SECRET=

# Bitbucket
BB_OAUTH_CLIENT_ID=
BB_OAUTH_CLIENT_SECRET=

# OVH (multiple regions)
NEXT_PUBLIC_ENABLE_OVH=false

# Jira
NEXT_PUBLIC_ENABLE_JIRA=false

# Atlassian OAuth (shared by Confluence + Jira)
# One OAuth app covers both products. Create at:
#   https://developer.atlassian.com/console/myapps/
# 1. Create > OAuth 2.0 integration > Name: "Aurora"
# 2. Permissions: add Confluence API scopes and/or Jira platform REST API scopes
# 3. Authorization > Callback URL: http://localhost:3000/atlassian/callback
# 4. Settings > copy Client ID and Secret below
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=

# SharePoint
NEXT_PUBLIC_ENABLE_SHAREPOINT=false
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_TENANT_ID=common

# Notion (OAuth is optional — integration-token flow works without NOTION_CLIENT_* values)
NEXT_PUBLIC_ENABLE_NOTION=false
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=

# Spinnaker
NEXT_PUBLIC_ENABLE_SPINNAKER=false

OVH_EU_CLIENT_ID=
OVH_EU_CLIENT_SECRET=
OVH_CA_CLIENT_ID=
OVH_CA_CLIENT_SECRET=
OVH_US_CLIENT_ID=
OVH_US_CLIENT_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Aurora

# -----------------------------------------------------------------------------
# Kubernetes & Pod Isolation
# -----------------------------------------------------------------------------
ENABLE_POD_ISOLATION=false
TERMINAL_NAMESPACE=
TERMINAL_IMAGE=
TERMINAL_POD_TTL=
TERMINAL_RUNTIME_CLASS=
CHATBOT_POD_TTL=
USE_UNTRUSTED_NODES=
NEXT_PUBLIC_KUBECTL_AGENT_CHART_URL=

# -----------------------------------------------------------------------------
# Weaviate (Vector Database)
# -----------------------------------------------------------------------------
WEAVIATE_HOST=weaviate
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# -----------------------------------------------------------------------------
# SSL/TLS for External Services
# -----------------------------------------------------------------------------
# PostgreSQL: "prefer" auto-negotiates TLS (works for RDS/Cloud SQL out of box)
# Set to "require" to enforce, "verify-ca"/"verify-full" with POSTGRES_SSLROOTCERT
POSTGRES_SSLMODE=prefer
POSTGRES_SSLROOTCERT=

# Redis: use rediss:// URL scheme to enable TLS (e.g., REDIS_URL=rediss://host:6380/0)
REDIS_SSL_CA_CERTS=
REDIS_SSL_CERT_REQS=

# Weaviate: set to true for external instances with HTTPS+gRPC-TLS
WEAVIATE_SECURE=false

# -----------------------------------------------------------------------------
# Memgraph (Graph Database)
# -----------------------------------------------------------------------------
MEMGRAPH_HOST=memgraph
MEMGRAPH_PORT=7687
MEMGRAPH_SCHEME=bolt              # Use "bolt+ssc" for Memgraph Cloud
MEMGRAPH_USER=                    # Optional: only needed for hosted/auth-enabled Memgraph
MEMGRAPH_PASSWORD=                # Optional: only needed for hosted/auth-enabled Memgraph
DISCOVERY_INTERVAL_HOURS=1

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMITING_ENABLED=false
RATE_LIMIT_BYPASS_TOKEN=
RATE_LIMIT_HEADERS_ENABLED=true

# -----------------------------------------------------------------------------
# Splunk SSL Verification
# Accepts: "false" (default), "true", or a path to a private CA bundle (e.g. /etc/ssl/certs/splunk-ca.pem)
# -----------------------------------------------------------------------------
SPLUNK_SSL_VERIFY=false

# -----------------------------------------------------------------------------
# MCP Server
# -----------------------------------------------------------------------------
MCP_PORT=8811

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
NGROK_URL=
